# Скопируй этот файл в .env и заполни значения

# Groq API ключ — БЕСПЛАТНО, только email, без карты
# Получить: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_...

# Telegram Bot Token — создать у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...

# База данных (оставь как есть)
DATABASE_URL=sqlite:///./nomad_tracker.db
